generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 Int                 @id @default(autoincrement())
  email              String              @unique
  passwordHash       String
  fullName           String
  avatarUrl          String?
  role               Role                @default(STUDENT)
  isActive           Boolean             @default(true)
  status             UserStatus          @default(ACTIVE)
  phone              String?
  lastLoginAt        DateTime?
  blockedAt          DateTime?
  blockedReason      String?
  blockedBy          String?
  googleId           String?             @unique
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  isPro              Boolean             @default(false)
  emailVerified      Boolean             @default(false)
  onboardingComplete Boolean             @default(true)
  notifications      Notification[]
  roleChangeRequests RoleChangeRequest[]
  student            Student?
  teacher            Teacher?
  referredBy         Int?
  referrer           User?                @relation("UserReferral", fields: [referredBy], references: [id])
  referredUsers      User[]               @relation("UserReferral")
  asReferral         Referral?            @relation("ReferredUser")
  affiliate          Affiliate?

  // Forum Relations
  forumPosts         ForumPost[]
  forumComments      ForumComment[]
  forumReactions     ForumReaction[]
  savedPosts         SavedForumPost[]
  moderatedCategories ForumCategory[]     @relation("CategoryModerators")
  createdGroups      StudyGroup[]        @relation("GroupCreator")
  groupMemberships   StudyGroupMember[]
  announcements      GroupAnnouncement[]
  reviewedResources  ResourceShare[]     @relation("ReviewedResources")
  reputations        ReputationHistory[]
  badges             UserBadge[]
  gamification       UserGamification?
  reportsSubmitted   ForumReport[]       @relation("Reporter")
  reportsResolved    ForumReport[]       @relation("Resolver")
  auditLogs          ForumAuditLog[]
  documentComments   DocumentComment[]
  mindmaps           Mindmap[]
  dailyContributions DailyContribution[]
  subjectStreaks     SubjectStreak[]
  leaderboardSnapshots LeaderboardSnapshot[]
  nodeProgress         NodeProgress[]
  nodeQuizAttempts     NodeQuizAttempt[]
  examAnalyses         ExamPaperAnalysis[]
  uploadedExamFiles    UploadedExamFile[]
  weaknessMindmaps     WeaknessMindmap[]
  apiAuditLogs         AuditLog[]
  userDocuments        UserDocument[]
  systemLogs           SystemLog[]
  reportsCreated       Report[]            @relation("ReportReporter")
  reportsReviewed      Report[]            @relation("ReportResolver")
  warningsReceived     Warning[]           @relation("UserWarnings")
  learningAttendances  LearningAttendance[]
  userEffort           UserEffort?
  voucherUsages        VoucherUsage[]
  voucherReservations  VoucherReservation[]
}


model Student {
  userId       Int             @id
  subjectGroup String
  chatMessages ChatMessage[]
  enrollments  Enrollment[]
  reviews      Review[]
  roadmap      Roadmap?
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  testAttempts TestAttempt[]
  totalAiQuestions Int             @default(0)
  grade        Int?
  province     String?
  school       String?
  targetScore      Float?
  targetUniversity String?

  @@index([grade])
  @@index([province])
}

model Teacher {
  userId          Int              @id
  isApproved      Boolean          @default(false)
  bio             String?          @db.Text
  courses         Course[]
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  materials       TeacherMaterial[]
  subjects        String?
  education       String?
  university      String?
  experienceYears Int              @default(0)
  dob             DateTime?
  cvUrl           String?
  degreeUrl       String?
  certificateUrl  String?
  status          RequestStatus    @default(PENDING)
  approvedAt      DateTime?
  approvedBy      Int?
  rejectedAt      DateTime?
  rejectedBy      Int?
  rejectedReason  String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @default(now()) @updatedAt
}



model Course {
  id             Int              @id @default(autoincrement())
  title          String
  description    String
  subject        String
  level          String?
  grade          Int?
  price          Float
  discount       Int              @default(0)
  thumbnailUrl   String?
  isPublished    Boolean          @default(false)
  isApproved     Boolean          @default(false)
  teacherId      Int
  teacher        Teacher          @relation(fields: [teacherId], references: [userId], onDelete: Cascade)
  enrollments    Enrollment[]
  lessons        Lesson[]
  reviews        Review[]
  status         CourseStatus     @default(DRAFT)
  visibility     CourseVisibility @default(HIDDEN)
  submittedAt    DateTime?
  approvedAt     DateTime?
  approvedBy     Int?
  rejectedAt     DateTime?
  rejectedBy     Int?
  rejectedReason String?          @db.Text
  hiddenAt       DateTime?
  hiddenBy       Int?
  hiddenReason   String?          @db.Text
}

model Lesson {
  id        Int        @id @default(autoincrement())
  courseId  Int
  title     String
  order     Int
  videoUrl  String?
  content   String?
  duration  String
  documents Document[]
  course    Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model Enrollment {
  id            Int      @id @default(autoincrement())
  studentId     Int
  courseId      Int
  paidAt        DateTime @default(now())
  transactionId String   @unique
  progress      Int      @default(0)
  amount        Float    @default(0)
  course        Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
}

model Question {
  id             Int                 @id @default(autoincrement())
  content        String
  options        Json
  correctAnswer  String
  explanation    String?
  subject        String
  topic          String
  difficulty     Difficulty          @default(MEDIUM)
  createdBy      Int
  imageUrl       String?
  audioUrl       String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @default(now()) @updatedAt
  examQuestions  ExamQuestion[]
  attemptAnswers TestAttemptAnswer[]
}

model Exam {
  id             Int            @id @default(autoincrement())
  title          String
  subject        String
  subjectGroup   String
  duration       Int
  isPublic       Boolean        @default(false)
  createdBy      Int
  year           Int?
  source         String?
  totalQuestions Int            @default(0)
  difficulty     Difficulty     @default(MEDIUM)
  status         String         @default("pending")
  grade          Int?
  approvedAt     DateTime?
  approvedBy     Int?
  rejectedAt     DateTime?
  rejectedBy     Int?
  rejectedReason String?        @db.Text
  hiddenAt       DateTime?
  hiddenBy       Int?
  hiddenReason   String?        @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @default(now()) @updatedAt
  examQuestions  ExamQuestion[]
  attempts       TestAttempt[]
}

model ExamQuestion {
  examId     Int
  questionId Int
  order      Int
  exam       Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@id([examId, questionId])
}

model TestAttempt {
  id                  Int                 @id @default(autoincrement())
  studentId           Int
  examId              Int
  score               Float
  startedAt           DateTime            @default(now())
  submittedAt         DateTime?
  aiFeedback          Json?
  durationUsed        Int?
  correctCount        Int?
  wrongCount          Int?
  skippedCount        Int?
  tabSwitchCount      Int                 @default(0)
  copyPasteCount      Int                 @default(0)
  fullscreenExitCount Int                 @default(0)
  examTrustScore      Float?
  topicStats          Json?
  difficultyStats     Json?
  status              AttemptStatus       @default(IN_PROGRESS)
  exam                Exam                @relation(fields: [examId], references: [id], onDelete: Cascade)
  student             Student             @relation(fields: [studentId], references: [userId], onDelete: Cascade)
  attemptAnswers      TestAttemptAnswer[]
  examEvents          ExamEvent[]

  @@index([studentId, status])
  @@index([examId])
}

model ExamEvent {
  id         Int         @id @default(autoincrement())
  attemptId  Int
  attempt    TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  eventType  String
  questionId Int?
  payload    Json?
  createdAt  DateTime    @default(now())

  @@index([attemptId])
  @@index([eventType])
}

model TestAttemptAnswer {
  id             Int         @id @default(autoincrement())
  attemptId      Int
  questionId     Int
  selectedAnswer String
  isCorrect      Boolean
  attempt        TestAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([attemptId, questionId])
}

model Roadmap {
  studentId   Int      @id
  content     Json
  generatedAt DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  studentId Int
  role      String
  content   String
  roomId    String
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
}
enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum NotificationCategory {
  SYSTEM
  ACCOUNT
  COURSE
  EXAM
  PAYMENT
  AI
  REPORT
  TEACHER
  ADMIN
}

model Notification {
  id        Int                  @id @default(autoincrement())
  userId    Int
  title     String
  message   String
  type      NotificationType     @default(INFO)
  category  NotificationCategory @default(SYSTEM)
  icon      String?
  link      String?
  isRead    Boolean              @default(false)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime             @default(now())
  updatedAt DateTime             @default(now()) @updatedAt
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationTemplate {
  id          Int                  @id @default(autoincrement())
  code        String               @unique
  title       String
  message     String
  type        NotificationType     @default(INFO)
  category    NotificationCategory @default(SYSTEM)
  icon        String?
  defaultLink String?
  isActive    Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @default(now()) @updatedAt
}

model Review {
  id        Int      @id @default(autoincrement())
  courseId  Int
  studentId Int
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [userId], onDelete: Cascade)
}

model Document {
  id         Int      @id @default(autoincrement())
  title      String
  fileUrl    String
  fileType   String
  lessonId   Int
  uploadedBy Int
  createdAt  DateTime @default(now())
  lesson     Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
}

model UserDocument {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  fileUrl   String
  fileType  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  GUEST
  STUDENT
  TEACHER
  ADMIN
  AFFILIATE
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum AttemptStatus {
  IN_PROGRESS
  SUBMITTED
  TIMEOUT
}

enum OtpPurpose {
  REGISTRATION
  PASSWORD_RESET
  EMAIL_CHANGE
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model OtpVerification {
  id          Int        @id @default(autoincrement())
  email       String
  otpHash     String
  purpose     OtpPurpose @default(REGISTRATION)
  payload     Json?
  attempts    Int        @default(0)
  maxAttempts Int        @default(5)
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  isUsed      Boolean    @default(false)

  @@index([email, purpose])
}

model RoleChangeRequest {
  id            Int           @id @default(autoincrement())
  userId        Int
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  currentRole   Role
  requestedRole Role
  reason        String?
  status        RequestStatus @default(PENDING)
  reviewedBy    Int?
  reviewedAt    DateTime?
  createdAt     DateTime      @default(now())

  @@index([userId, status])
}

// =========================================================================
// FORUM SYSTEM MODEL EXTENSIONS
// =========================================================================

enum PostType {
  GENERAL
  QA
  RESOURCE
}

enum GroupRole {
  CREATOR
  ADMIN
  MEMBER
}

enum ResourceStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ReputationAction {
  POST_CREATED
  COMMENT_CREATED
  UPVOTE_RECEIVED
  DOWNVOTE_RECEIVED
  ACCEPTED_ANSWER
  DAILY_STREAK
  RESOURCE_DOWNLOADED
}

enum BadgeCategory {
  POSTING
  ANSWERS
  RESOURCE_SHARING
  REPUTATION
  SPECIAL
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model ForumCategory {
  id             Int             @id @default(autoincrement())
  name           String
  slug           String          @unique
  description    String?
  parentId       Int?
  parent         ForumCategory?  @relation("CategoryNesting", fields: [parentId], references: [id], onDelete: Cascade)
  subCategories  ForumCategory[] @relation("CategoryNesting")
  allowedRoles   Role[]          @default([STUDENT, TEACHER, ADMIN])
  posts          ForumPost[]
  moderators     User[]          @relation("CategoryModerators")
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([parentId])
}

model ForumPost {
  id             Int             @id @default(autoincrement())
  title          String
  content        String          @db.Text
  slug           String          @unique
  postType       PostType        @default(GENERAL)
  categoryId     Int
  category       ForumCategory   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  authorId       Int
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  
  isPinned       Boolean         @default(false)
  isArchived     Boolean         @default(false)
  isDraft        Boolean         @default(false)
  scheduledAt    DateTime?
  
  difficulty     Difficulty?
  viewsCount     Int             @default(0)
  
  comments       ForumComment[]
  reactions      ForumReaction[]
  tags           ForumTag[]      @relation("PostTags")
  resource       ResourceShare?
  studyGroupId   Int?
  studyGroup     StudyGroup?     @relation(fields: [studyGroupId], references: [id], onDelete: SetNull)
  reports        ForumReport[]
  savedBy        SavedForumPost[]
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([categoryId])
  @@index([authorId])
  @@index([postType])
}

model ForumComment {
  id             Int             @id @default(autoincrement())
  postId         Int
  post           ForumPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  parentId       Int?
  parent         ForumComment?   @relation("CommentNesting", fields: [parentId], references: [id], onDelete: Cascade)
  replies        ForumComment[]  @relation("CommentNesting")
  authorId       Int
  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content        String          @db.Text
  
  isSolution     Boolean         @default(false)
  
  reactions      ForumReaction[]
  reports        ForumReport[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([postId])
  @@index([parentId])
  @@index([authorId])
}

model ForumReaction {
  id             Int             @id @default(autoincrement())
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId         Int?
  post           ForumPost?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId      Int?
  comment        ForumComment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  
  type           String
  createdAt      DateTime        @default(now())

  @@unique([userId, postId, type])
  @@unique([userId, commentId, type])
  @@index([postId])
  @@index([commentId])
}

model SavedForumPost {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId    Int
  post      ForumPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@unique([userId, postId])
  @@index([userId])
  @@index([postId])
}

model ForumTag {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  slug           String          @unique
  posts          ForumPost[]     @relation("PostTags")
}

model StudyGroup {
  id             Int                @id @default(autoincrement())
  name           String
  description    String?            @db.Text
  avatarUrl      String?
  isPrivate      Boolean            @default(false)
  creatorId      Int
  creator        User               @relation("GroupCreator", fields: [creatorId], references: [id])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  
  members        StudyGroupMember[]
  posts          ForumPost[]
  announcements  GroupAnnouncement[]
}

model StudyGroupMember {
  id             Int             @id @default(autoincrement())
  groupId        Int
  group          StudyGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           GroupRole       @default(MEMBER)
  joinedAt       DateTime        @default(now())

  @@unique([groupId, userId])
  @@index([userId])
}

model GroupAnnouncement {
  id             Int             @id @default(autoincrement())
  groupId        Int
  group          StudyGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  title          String
  content        String          @db.Text
  authorId       Int
  author         User            @relation(fields: [authorId], references: [id])
  createdAt      DateTime        @default(now())
}

model ResourceShare {
  id             Int             @id @default(autoincrement())
  postId         Int             @unique
  post           ForumPost       @relation(fields: [postId], references: [id], onDelete: Cascade)
  fileUrl        String
  fileType       String
  fileSize       Int
  downloadCount  Int             @default(0)
  
  ratingSum      Int             @default(0)
  ratingCount    Int             @default(0)
  version        Int             @default(1)
  status         ResourceStatus  @default(PENDING)
  
  reviewedById   Int?
  reviewedBy     User?           @relation("ReviewedResources", fields: [reviewedById], references: [id])
  reviewedAt     DateTime?
  
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([status])
}

model ReputationHistory {
  id             Int              @id @default(autoincrement())
  userId         Int
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  points         Int
  action         ReputationAction
  referenceId    String?
  createdAt      DateTime         @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Badge {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  description    String
  iconUrl        String
  category       BadgeCategory   @default(POSTING)
  criteria       Json
  users          UserBadge[]
}

model UserBadge {
  userId         Int
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  badgeId        Int
  badge          Badge           @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  unlockedAt     DateTime        @default(now())

  @@id([userId, badgeId])
}

model UserGamification {
  userId            Int             @id
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  level             Int             @default(1)
  xp                Int             @default(0)
  streakDays        Int             @default(0)
  lastActiveDate    DateTime?
  milestonesReached Json?

  updatedAt         DateTime        @updatedAt

  @@index([xp])
  @@index([streakDays])
}

model ForumReport {
  id             Int             @id @default(autoincrement())
  reporterId     Int
  reporter       User            @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  postId         Int?
  post           ForumPost?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  commentId      Int?
  comment        ForumComment?   @relation(fields: [commentId], references: [id], onDelete: Cascade)
  reason         String
  status         ReportStatus    @default(PENDING)
  
  resolvedById   Int?
  resolvedBy     User?           @relation("Resolver", fields: [resolvedById], references: [id])
  resolvedAt     DateTime?
  resolutionNotes String?
  
  createdAt      DateTime        @default(now())

  @@index([status])
}

model ForumAuditLog {
  id             Int             @id @default(autoincrement())
  actorId        Int
  actor          User            @relation(fields: [actorId], references: [id])
  action         String
  targetId       String
  details        String?
  ipAddress      String?
  createdAt      DateTime        @default(now())
}

model DocumentResource {
  id                  Int      @id @default(autoincrement())
  title               String
  description         String?  @db.Text
  subject             String
  level               String
  isFree              Boolean  @default(false)
  driveUrl            String?
  imageUrl            String?
  price               Int      @default(0)
  isActive            Boolean  @default(true)
  isDeleted           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @default(now()) @updatedAt
  commissionPercent   Float?
  markdownDescription String?  @db.Text
  comments            DocumentComment[]

  @@map("document_resources")
}

model DocumentComment {
  id         Int      @id @default(autoincrement())
  documentId Int
  userId     Int
  content    String   @db.Text
  createdAt  DateTime @default(now())

  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  document   DocumentResource @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_comments")
}

model Mindmap {
  id           Int                @id @default(autoincrement())
  userId       Int
  title        String
  content      Json
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt @default(now())

  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes        MindmapNode[]
  examAnalysis ExamPaperAnalysis? @relation("ExamMindmap")

  @@map("mindmaps")
}

model Lead {
  id             Int      @id @default(autoincrement())
  name           String
  phone          String
  email          String
  target         String
  registeredDate DateTime @default(now())
  status         String   @default("Chờ tư vấn")
}

model FeatureFlag {
  id        String   @id
  name      String
  isEnabled Boolean  @default(true)
  updatedAt DateTime @updatedAt
}


model DailyContribution {
  id              Int      @id @default(autoincrement())
  userId          Int
  date            DateTime // Normalized YYYY-MM-DD
  exerciseCount   Int      @default(0)
  examsCompleted  Int      @default(0)
  lessonsCompleted Int     @default(0)
  studyMinutes    Int      @default(0)
  xpEarned        Int      @default(0)
  subjectsStudied Json     // Array of subject tags e.g. ["math", "physics"]
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
}

model SubjectStreak {
  id           Int      @id @default(autoincrement())
  userId       Int
  subject      String   // "math", "physics", etc.
  currentStreak Int     @default(0)
  longestStreak Int     @default(0)
  lastActive   DateTime?
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, subject])
}

model LeaderboardSnapshot {
  id           Int      @id @default(autoincrement())
  dimensionKey String   // e.g. "grade_12_math_danang"
  rank         Int
  userId       Int
  score        Float
  xp           Int
  streakDays   Int
  updatedAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([dimensionKey, rank])
}

model MindmapNode {
  id          Int      @id @default(autoincrement())
  mindmapId   Int
  nodeKey     String   // e.g. "0-1-0"
  name        String
  description String   @db.Text
  createdAt   DateTime @default(now())

  mindmap     Mindmap          @relation(fields: [mindmapId], references: [id], onDelete: Cascade)
  progress    NodeProgress[]
  attempts    NodeQuizAttempt[]
  questions   QuizQuestion[]

  @@unique([mindmapId, nodeKey])
  @@map("mindmap_nodes")
}

model NodeProgress {
  id            Int      @id @default(autoincrement())
  userId        Int
  mindmapNodeId Int
  mastery       Float    @default(0.0) // 0.0 to 1.0
  bestScore     Int      @default(0)   // out of 10
  attempts      Int      @default(0)
  lastPracticed DateTime @default(now()) @updatedAt

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  node          MindmapNode  @relation(fields: [mindmapNodeId], references: [id], onDelete: Cascade)

  @@unique([userId, mindmapNodeId])
  @@map("node_progress")
}

model QuizQuestion {
  id            Int      @id @default(autoincrement())
  mindmapNodeId Int
  questionText  String   @db.Text
  options       Json     // array of strings
  correctOption Int      // index 0-3
  explanation   String   @db.Text
  createdAt     DateTime @default(now())

  node          MindmapNode  @relation(fields: [mindmapNodeId], references: [id], onDelete: Cascade)
  userAnswers   UserAnswer[]

  @@map("quiz_questions")
}

model NodeQuizAttempt {
  id            Int      @id @default(autoincrement())
  userId        Int
  mindmapNodeId Int
  score         Int
  totalQuestions Int     @default(10)
  completionTime Int     // in seconds
  createdAt     DateTime @default(now())

  user          User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  node          MindmapNode  @relation(fields: [mindmapNodeId], references: [id], onDelete: Cascade)
  answers       UserAnswer[]

  @@map("node_quiz_attempts")
}

model UserAnswer {
  id             Int      @id @default(autoincrement())
  attemptId      Int
  questionId     Int
  selectedOption Int
  isCorrect      Boolean
  createdAt      DateTime @default(now())

  attempt        NodeQuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       QuizQuestion    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("user_answers")
}

model WeaknessMindmap {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  content   Json
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("weakness_mindmaps")
}

model ExamPaperAnalysis {
  id              Int      @id @default(autoincrement())
  userId          Int
  title           String
  subject         String
  grade           String
  analysisResult  Json
  mindmapId       Int?     @unique
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mindmap         Mindmap? @relation("ExamMindmap", fields: [mindmapId], references: [id], onDelete: SetNull)
  files           UploadedExamFile[]

  @@map("exam_paper_analyses")
}

model UploadedExamFile {
  id          Int      @id @default(autoincrement())
  userId      Int
  filename    String
  fileUrl     String
  fileType    String
  analysisId  Int?
  createdAt   DateTime @default(now())

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis    ExamPaperAnalysis? @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@map("uploaded_exam_files")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userRole  Role
  action    String
  target    String
  payload   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AffiliateTier {
  BRONZE
  SILVER
  GOLD
  PLATINUM
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

model Affiliate {
  userId           Int               @id
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  referralCode     String            @unique
  commissionRate   Float             @default(0.15)
  totalEarnings    Float             @default(0)
  pendingEarnings  Float             @default(0)
  paidEarnings     Float             @default(0)
  tier             AffiliateTier     @default(BRONZE)
  bankAccount      String?
  bankName         String?
  taxId            String?
  payoutMethod     String?
  isApproved       Boolean           @default(false)
  approvedAt       DateTime?
  createdAt        DateTime          @default(now())
  referrals        Referral[]
  commissions      Commission[]
  payouts          Payout[]
  materials        AffiliateMaterial[]
}

model Referral {
  id              Int        @id @default(autoincrement())
  affiliateId     Int
  affiliate       Affiliate  @relation(fields: [affiliateId], references: [userId], onDelete: Cascade)
  referredUserId  Int        @unique
  referredUser    User       @relation("ReferredUser", fields: [referredUserId], references: [id], onDelete: Cascade)
  source          String?
  campaign        String?
  clickedAt       DateTime   @default(now())
  convertedAt     DateTime?
  isConverted     Boolean    @default(false)
}

model Commission {
  id            Int        @id @default(autoincrement())
  affiliateId   Int
  affiliate     Affiliate  @relation(fields: [affiliateId], references: [userId], onDelete: Cascade)
  orderId       Int
  amount        Float
  rate          Float
  status        CommissionStatus @default(PENDING)
  earnedAt      DateTime   @default(now())
  approvedAt    DateTime?
  paidAt        DateTime?
}

model Payout {
  id            Int       @id @default(autoincrement())
  affiliateId   Int
  affiliate     Affiliate @relation(fields: [affiliateId], references: [userId], onDelete: Cascade)
  amount        Float
  method        String
  status        String    @default("PENDING")
  requestedAt   DateTime  @default(now())
  completedAt   DateTime?
  transactionId String?
  receiptUrl    String?
}

model AffiliateMaterial {
  id            Int       @id @default(autoincrement())
  affiliateId   Int
  affiliate     Affiliate @relation(fields: [affiliateId], references: [userId], onDelete: Cascade)
  type          String
  targetUrl     String
  imageUrl      String?
  copy          String?
  clicks        Int       @default(0)
  conversions   Int       @default(0)
  createdAt     DateTime  @default(now())
}

model TeacherMaterial {
  id            Int       @id @default(autoincrement())
  teacherId     Int
  teacher       Teacher   @relation(fields: [teacherId], references: [userId], onDelete: Cascade)
  title         String
  description   String?
  subject       String
  grade         String?
  fileUrl       String
  fileType      String
  fileSize      Int
  thumbnailUrl  String?
  tags          String[]
  isPublic      Boolean   @default(false)
  isApproved    Boolean   @default(false)
  downloadCount Int       @default(0)
  viewCount     Int       @default(0)
  price         Float     @default(0)
  uploadedAt    DateTime  @default(now())
}

// ── Thống kê hàng tháng (Dashboard Admin) ──
model MonthlyStatistic {
  id               Int      @id @default(autoincrement())
  month            Int      // 1-12
  year             Int      // ví dụ: 2026
  totalUsers       Int      @default(0)
  newUsers         Int      @default(0)
  totalAttempts    Int      @default(0)
  totalAiQuestions Int      @default(0)
  revenue          Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([month, year])
  @@map("monthly_statistics")
}

// ── Thống kê theo ngày (Chart dữ liệu chi tiết) ──
model DailyStatistic {
  id               Int      @id @default(autoincrement())
  date             DateTime @unique // chuẩn hóa về 00:00:00 UTC
  newUsers         Int      @default(0)
  totalAttempts    Int      @default(0)
  totalAiQuestions Int      @default(0)
  revenue          Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("daily_statistics")
}

enum CourseStatus {
  DRAFT
  PENDING
  APPROVED
  REJECTED
}

enum CourseVisibility {
  VISIBLE
  HIDDEN
}

model Report {
  id             Int       @id @default(autoincrement())
  reporterId     Int
  reporter       User      @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  targetType     String    // e.g. "COURSE", "COMMENT"
  targetId       Int
  reason         String
  description    String?   @db.Text
  status         String    @default("PENDING") // e.g. "PENDING", "APPROVED", "REJECTED", "CLOSED"
  reviewedAt     DateTime?
  reviewedBy     Int?
  resolver       User?     @relation("ReportResolver", fields: [reviewedBy], references: [id], onDelete: SetNull)
  resolutionNote String?   @db.Text
  createdAt      DateTime  @default(now())
  warnings       Warning[]

  @@map("reports")
}

model Warning {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("UserWarnings", fields: [userId], references: [id], onDelete: Cascade)
  reportId  Int
  report    Report   @relation(fields: [reportId], references: [id], onDelete: Cascade)
  message   String   @db.Text
  createdAt DateTime @default(now())

  @@map("warnings")
}

model SystemLog {
  id              Int        @id @default(autoincrement())
  type            LogType
  action          String
  module          String
  userId          Int?
  user            User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  ipAddress       String?
  device          String?
  browser         String?
  operatingSystem String?
  description     String     @db.Text
  metadata        Json?
  level           LogLevel
  createdAt       DateTime   @default(now())
  syncedToGoogle  Boolean    @default(false)
  syncedAt        DateTime?

  @@map("system_logs")
}



enum LogType {
  LOGIN
  ADMIN
  SYSTEM
}

enum LogLevel {
  INFO
  WARNING
  ERROR
  CRITICAL
}

model LearningAttendance {
  id        Int      @id @default(autoincrement())
  userId    Int
  date      DateTime // Normalized YYYY-MM-DD
  activity  String   // "LESSON" | "TEST" | "MINDMAP" | "FLASHCARD"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date, activity])
  @@map("learning_attendances")
}

model UserEffort {
  userId      Int      @id
  score       Int      @default(0)
  forumPoints Int      @default(0)
  studyPoints Int      @default(0)
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_efforts")
}

model SystemSetting {
  id          Int      @id @default(autoincrement())
  key         String   @unique
  value       String
  type        String   // "STRING" | "NUMBER" | "BOOLEAN"
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_settings")
}

enum VoucherStatus {
  ACTIVE
  INACTIVE
  EXPIRED
}

enum VoucherDiscountType {
  PERCENT
  FIXED
}

enum VoucherApplicableType {
  ALL
  COURSE
  PREMIUM
  SPECIFIC_COURSES
}

model Voucher {
  id                  Int                   @id @default(autoincrement())
  code                String                @unique
  name                String
  description         String?               @db.Text
  discountType        VoucherDiscountType
  discountValue       Float                 // Tỉ lệ % hoặc số tiền cố định
  minimumOrderValue   Float                 @default(0) // Giá trị đơn hàng tối thiểu
  maximumDiscount     Float?                // Giảm tối đa (chỉ áp dụng cho PERCENT)
  totalQuantity       Int?                  // Tổng lượt sử dụng tối đa (null = không giới hạn)
  usedQuantity        Int                   @default(0)
  limitPerUser        Int                   @default(1) // Số lần sử dụng tối đa của mỗi user (1, 2, 5...)
  applicableType      VoucherApplicableType @default(ALL)
  applicableCourseIds Int[]                 // Danh sách mã khóa học cụ thể áp dụng
  status              VoucherStatus         @default(ACTIVE)
  startDate           DateTime?
  endDate             DateTime?
  createdBy           Int
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt
  usages              VoucherUsage[]
  reservations        VoucherReservation[]

  @@map("vouchers")
}

model VoucherUsage {
  id             Int          @id @default(autoincrement())
  voucherId      Int
  voucher        Voucher      @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  userId         Int
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  paymentId      String?      // Mã giao dịch/hóa đơn liên quan (transactionId)
  discountAmount Float        // Số tiền thực tế đã giảm trong giao dịch
  usedAt         DateTime     @default(now())

  @@map("voucher_usages")
}

model VoucherReservation {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  voucherId Int
  voucher   Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  courseId  Int?     // null nếu nâng cấp Premium
  isPremium Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, voucherId, courseId, isPremium])
  @@map("voucher_reservations")
}





